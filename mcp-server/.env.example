# Copia este archivo a .env  ->  cp .env.example .env
# y rellena tus datos. El archivo .env NO se sube a git.
#
# Estas mismas variables se configuran luego en Claude (ver README.md).

# URL de la API. Por defecto apunta a producción (Railway). No la cambies
# salvo que quieras usar el backend local (http://localhost:3000/api).
AGENCIAPRO_API_URL=https://agenciapro-production.up.railway.app/api

# Credenciales de AgenciaPro (las mismas con las que entras a la app).
AGENCIAPRO_EMAIL=tu-correo@larealmarketing.com
AGENCIAPRO_PIN=tu-pin

# Alternativa: si prefieres no guardar el PIN, deja EMAIL/PIN vacíos y pega
# aquí un token ya emitido (dura 10 años). Ver README.md.
# AGENCIAPRO_TOKEN=
